# DrugAgent — plantilla de entorno (copiar a .env)
# Guía completa: INSTALL_WINDOWS.md

# ── Modo local-first (recomendado para demos públicas) ──
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.2
LOCAL_LLM_TIMEOUT=300
LOCAL_LLM_CONNECT_TIMEOUT=15
LOCAL_LLM_JSON_MODE=true

# Sin LLM en la nube: deja vacías las keys y usa solo LOCAL_LLM_BASE_URL
# OFFLINE_MODE=True  → solo heurísticas RDKit (sin Ollama ni Groq)

# ── LLM en la nube (opcional) ──
# GROQ_API_KEY=
# GEMINI_API_KEY=

# ── Base de datos y telemetría ──
DATABASE_URL=file:./data/drugagent.db
MLFLOW_TRACKING_URI=sqlite:///./data/mlflow.db
LOG_LEVEL=INFO

# ── Docking: auto | real | mock  (CLI también acepta DOCKING_MODE=vina → real)
DOCKING_MODE=auto

# ── Target por defecto (debe coincidir con catalog/therapeutic_areas.yaml) ──
DEFAULT_TARGET=EGFR
DEFAULT_PDB_ID=4HJO

# ── Evidencia pública ChEMBL (requiere internet; ver config.yaml evidence:) ──
# EVIDENCE_ENABLED=true

# ── Vina (Windows): colocar binario en tools/vina/vina.exe ──
# VINA_PATH=tools/vina/vina.exe
