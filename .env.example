# DrugAgent - Variables de Entorno
# ─────────────────────────────────────────────
# PASO 1: Obtén tu Groq API Key GRATIS en:
#         https://console.groq.com
# PASO 2: Reemplaza el valor de abajo con tu key real
# PASO 3: Guarda el archivo

GROQ_API_KEY=gsk_REEMPLAZA_CON_TU_KEY_REAL

# ─────────────────────────────────────────────
# OPCIONAL: Claude para revisión de reportes finales
# (No necesario para el MVP)
# ANTHROPIC_API_KEY=sk-ant-...
# ─────────────────────────────────────────────

# Paths en WSL2
VINA_PATH=/usr/local/bin/vina
REINVENT4_PATH=/root/REINVENT4
SCIAGENT_SKILLS_PATH=/root/SciAgent-Skills

# Configuración del agente
LOG_LEVEL=INFO
MLFLOW_TRACKING_URI=sqlite:///./data/mlflow.db

# Target por defecto
DEFAULT_TARGET=EGFR
DEFAULT_PDB_ID=4HJO

# LLM local (Ollama / LM Studio OpenAI-compatible)
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=llama3.1:8b
# LOCAL_LLM_TIMEOUT=300
# LOCAL_LLM_CONNECT_TIMEOUT=15
# LOCAL_LLM_JSON_MODE=true

# Evidencia publica ChEMBL (API recomendada; requiere internet)
# EVIDENCE_ENABLED=true
# EVIDENCE_MODE=api
